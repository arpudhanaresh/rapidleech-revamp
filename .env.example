# ── Server ─────────────────────────────────────────────────────────────────
PORT=8000
SECRET_KEY=change-me-to-a-random-string

# ── Database ────────────────────────────────────────────────────────────────
# Leave blank to use local SQLite (data/rapidleech.db) — zero config default
DATABASE_URL=
# PostgreSQL example:  postgresql+asyncpg://user:pass@localhost:5432/rapidleech
# MySQL example:       mysql+aiomysql://user:pass@localhost:3306/rapidleech

# ── Downloads ───────────────────────────────────────────────────────────────
DOWNLOAD_DIR=downloads
MAX_CONCURRENT=3
DEFAULT_CONNECTIONS=4
MAX_FILE_SIZE_GB=0
FILE_TTL_DEFAULT_HOURS=5
FILE_TTL_MAX_HOURS=12

# ── Torrent ──────────────────────────────────────────────────────────────────
TORRENT_MAX_CONNECTIONS=2000
TORRENT_MAX_CONNECTIONS_PER_TORRENT=500

# ── aria2 RPC (optional — install aria2c system-wide for max speed) ──────────
ARIA2_HOST=http://localhost
ARIA2_PORT=6800
ARIA2_RPC_SECRET=

# ── Security ────────────────────────────────────────────────────────────────
RATE_LIMIT_FETCH=5/minute
RATE_LIMIT_DOWNLOAD=30/minute

# ── ClamAV (optional — leave blank to skip virus scanning) ──────────────────
CLAM_SOCKET=
# Linux socket example: /var/run/clamav/clamd.ctl
# TCP example:          localhost:3310
